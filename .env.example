# Secrets and deployment-specific overrides.
TELEGRAM_TOKEN=
LLM_API_KEY=
EPG_SERVICE_API_KEY=
# EPG_SERVICE_BASE_URL=https://api.epgservice.ru

# SQLite is used by default.
DATABASE_DRIVER=sqlite
DATABASE_DSN=/data/remind.db

# Optional external PostgreSQL connection. DATABASE_URL takes precedence over
# DATABASE_DRIVER and DATABASE_DSN when it is set.
# DATABASE_URL=postgres://remind:password@host.docker.internal:5432/remind?sslmode=disable

LOG_LEVEL=info
