# All durations use Go's time.Duration format: 15s, 1m, 24h.
# ${VAR} values are substituted from the environment before YAML is parsed.

database:
  # Supported drivers: sqlite and postgres.
  driver: sqlite
  # For SQLite, specify the file path. The directory must be writable.
  dsn: ./data/remind.db
  # Example PostgreSQL DSN:
  # dsn: postgres://remind:remind@localhost:5432/remind?sslmode=disable
  # DATABASE_URL takes priority over driver and dsn and automatically selects postgres.

telegram:
  # Token from BotFather. A non-empty TELEGRAM_TOKEN overrides this field.
  token: "${TELEGRAM_TOKEN}"
  # The bot shows a persistent quick-command keyboard in Telegram clients.
  # No extra configuration is required; users can still type free-form text.

nlu:
  # LLM used for natural-language parsing: openrouter or claude.
  provider: openrouter
  # Shared key for the selected provider. Can also be passed via LLM_API_KEY.
  api_key: "${LLM_API_KEY}"
  claude:
    # Used only when provider: claude.
    model: claude-haiku-4-5-20251001
  openrouter:
    # OpenAI-compatible endpoint without /chat/completions.
    base_url: https://openrouter.ai/api/v1
    # Primary model, called first. Full catalog: https://openrouter.ai/models
    model: anthropic/claude-haiku-4-5
    # On rate limit (HTTP 429), the bot tries these models in order.
    fallback_models:
      - google/gemma-3-27b-it:free
      - meta-llama/llama-3.3-70b-instruct:free
    # Overall timeout for a single LLM call.
    timeout: 60s
    # Maximum model response size in tokens.
    max_tokens: 1024

providers:
  # Fallback EPG Service used by the worker only when iptvx.url is empty.
  # It supports TV reminders but does not populate the database for /tv.
  tv:
    # API v1 docs: https://epgservice.ru/en/docs/
    base_url: https://api.epgservice.ru
    # Bearer token; EPG_SERVICE_API_KEY takes priority over YAML.
    api_key: "${EPG_SERVICE_API_KEY}"
    # Timeout for a single index or schedule request.
    timeout: 15s

  # Primary TV schedule source. The worker downloads XMLTV, imports it into
  # the shared DB, and refreshes it; the bot reads this DB for /tv.
  iptvx:
    # XMLTV/XMLTV.GZ URL. An empty value switches the worker to providers.tv.
    # Full archive (~100 MB): https://iptvx.one/epg/epg.xml.gz
    # Lightweight (~15 MB):   https://iptvx.one/epg/epg_lite.xml.gz
    url: https://iptvx.one/epg/epg.xml.gz
    # Local cache path (absolute path inside the /data volume).
    # For running outside Docker, use ./data/iptvx_epg.xml.gz instead.
    file_path: /data/iptvx_epg.xml.gz
    # Freshness-check and refresh period (the file is published weekly).
    update_interval: 168h
    # Timeout for downloading the large EPG file.
    timeout: 120s

  price:
    # User-Agent for requests to store pages.
    user_agent: Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/125.0.0.0 Safari/537.36
    # Timeout for fetching the product page (HTTP mode) or loading it in the browser (headless).
    timeout: 15s
    # Use headless Chromium to bypass WAF/TLS fingerprinting.
    # Requires Chromium in the runtime image (docker-compose: debian:bookworm-slim + chromium).
    # false — plain HTTP client, works for most stores.
    # true  — real browser, needed for sites with aggressive protection (Qrator, Cloudflare).
    headless: false
    # Proxy for the headless browser. Required for sites (e.g. DNS-shop) that
    # block by IP/TLS fingerprint. HTTP, HTTPS, and SOCKS5 are supported:
    #   proxy_url: http://user:pass@proxy.example.com:3128
    #   proxy_url: socks5://user:pass@proxy.example.com:1080
    # Empty value — direct connection without a proxy.
    proxy_url: ""
    # Default poll schedule for a product page (5-field cron, UTC).
    # Applied when the user did not specify an interval in the reminder text.
    # Examples:
    #   0 * * * *     — every hour            (recommended)
    #   0 */4 * * *   — every 4 hours
    #   0 */12 * * *  — twice a day
    #   0 9 * * *     — daily at 09:00 UTC
    poll_cron: "0 9 * * *"

  travel:
    # An empty key disables the corresponding ticket source.
    air_api_key: ""
    rail_api_key: ""
    # Timeout for a request to the offers source.
    timeout: 10s
    # Maximum search depth from the current date.
    max_horizon_days: 180

  rss:
    # Timeout for fetching and parsing one RSS/Atom feed for the /rss command.
    timeout: 15s
    # Use the LLM (same nlu.* provider/model settings) to pick and
    # re-summarize the most important items in each digest, instead of the
    # keyword+recency heuristic. Adds one LLM call per digest tick; falls
    # back to the heuristic automatically if that call fails.
    llm_digest: false
    # Proxy for fetching RSS/Atom feeds. Some feeds block requests from
    # datacenter/VPS IP ranges outright; routing through a proxy is the only
    # way to reach those. HTTP, HTTPS, and SOCKS5 are supported:
    #   proxy_url: http://user:pass@proxy.example.com:3128
    #   proxy_url: socks5://user:pass@proxy.example.com:1080
    # Empty value — fetch directly, no proxy.
    proxy_url: ""

scheduler:
  # Interval for finding reminders that are due for evaluation.
  watcher_tick: 1m
  # Interval for delivering prepared Telegram notifications.
  delivery_tick: 15s
  # Interval for cleaning up stale internal data.
  housekeeping_tick: 1h

server:
  # Worker ID used for the lease; an empty value is generated automatically.
  worker_id: ""
  # Allowed levels: debug, info, warn, error.
  # At info level, LLM requests log provider/model and fallback selection,
  # without logging prompts, responses, or API keys.
  log_level: info
